# TIE - Trivin Insight Engine
# Environment Configuration Example

# Project Settings
PROJECT_NAME=TIE
PROJECT_VERSION=1.0.0
ENVIRONMENT=development

# Data Paths (relative to project root)
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed
SAMPLE_DATA_PATH=data/sample

# Output Paths
FIGURES_OUTPUT_PATH=outputs/figures
REPORTS_OUTPUT_PATH=outputs/reports
EXPORTS_OUTPUT_PATH=outputs/exports

# Analysis Settings
SATISFACTION_THRESHOLD=2
MIN_TOPIC_WORDS=10
MAX_TOPIC_WORDS=20
NUM_TOPICS=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=outputs/app.log

# Dashboard Settings
DASHBOARD_PORT=8501
DASHBOARD_HOST=localhost
